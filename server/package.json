{
  "name": "headlenss-server",
  "version": "0.1.0",
  "private": true,
  "description": "headlenss server: tmux session management API + xterm.js web UI",
  "type": "module",
  "scripts": {
    "setup": "node scripts/setup-whisper.mjs",
    "dev": "concurrently -k -n server,web -c blue,green \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "tsx --env-file-if-exists=.env watch src/server/index.ts",
    "dev:web": "vite",
    "build": "vite build",
    "start": "tsx --env-file-if-exists=.env src/server/index.ts",
    "typecheck": "tsc --noEmit",
    "service:install": "node scripts/install-systemd.mjs",
    "service:status": "systemctl --user status headlenss",
    "service:logs": "journalctl --user -u headlenss -f"
  },
  "dependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.14.0",
    "@hono/node-server": "^1.13.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/headless": "^6.0.0",
    "hono": "^4.6.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.5.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "concurrently": "^9.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
