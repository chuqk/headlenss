# headlenss server configuration
# Copy this file to `.env` and uncomment / set values you need.
# `.env` is gitignored. Loaded on `npm start`, `npm run dev`, and by the systemd unit.

# ===== Server =====
# PORT=3000
# HOST のデフォルトは 127.0.0.1 (ローカル限定)。
# 他端末から触らせる場合のみ明示的に 0.0.0.0 や特定 IP を指定する。
# その場合は認証が無い前提なので、必ず ALLOWED_ORIGINS と組み合わせて使うこと。
# HOST=0.0.0.0

# ===== CORS / WebSocket Origin allowlist =====
# `/api/*` の CORS と `/api/sessions/:name/pty` の WebSocket Upgrade で
# 許可する Origin を CSV で列挙する。未指定なら localhost 系のみ許可される。
# 例: ALLOWED_ORIGINS=http://localhost:3000,http://your-host.tailnet.ts.net:3000
# ALLOWED_ORIGINS=

# ===== tmux 起動ラッパー (現状は polkit 設定なしでは効かない) =====
# 指定すると `tmux new-session` の前にこのコマンドが前置される。
# 設計上は次の値で tmux サーバを別 scope に追い出して headlenss.service の
# cgroup の外に出せるが、systemctl --user で起動された service からこれを
# 呼ぶと polkit が「Interactive authentication required」で拒否するため、
# 現状のデフォルト Ubuntu 環境では動かない (subuntu で実機検証済)。
# 動かしたい場合は /etc/polkit-1/rules.d/ に該当ルールを追加する必要がある。
# 末尾の `--` は systemd-run の引数終端なので必ず含めること。
# HEADLENSS_TMUX_WRAPPER=systemd-run --user --scope --quiet --collect --

# ===== ASR backend selection =====
# whisper-cpp (default, local), amivoice (cloud, JP), speechmatics (cloud, multilingual)
# ASR_BACKEND=whisper-cpp

# ----- whisper-cpp (run `npm run setup` first) -----
# WHISPER_MODEL=ggml-large-v3-turbo-q5_0.bin
# WHISPER_LANG=auto
# WHISPER_THREADS=4

# ----- Speechmatics (https://portal.speechmatics.com/) -----
# SPEECHMATICS_API_KEY=
# SPEECHMATICS_LANG=ja
# SPEECHMATICS_OPERATING_POINT=enhanced

# ----- AmiVoice (https://acp.amivoice.com/) -----
# AMIVOICE_APPKEY=
# AMIVOICE_ENGINE=-a-general-input
# AMIVOICE_ALLOW_LOGGING=false
